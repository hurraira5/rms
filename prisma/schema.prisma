generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Restaurant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique 
  trialEnds    DateTime
  status       String   @default("Active")
  branches     Branch[]
}

model Branch {
  id            String   @id @default(cuid())
  name          String
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
}